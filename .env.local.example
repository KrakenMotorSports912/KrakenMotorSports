# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin Configuration
# Change this to your admin email after setting up
ADMIN_EMAIL=your-admin-email@example.com

# PayPal/Payment Links (for Founders Pass)
NEXT_PUBLIC_FOUNDERS_PASS_PAYPAL=your_paypal_me_link
NEXT_PUBLIC_FOUNDERS_PASS_VENMO=your_venmo_username

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DISCORD_INVITE=https://discord.gg/5DJtSRfaZZ
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/krakenmotorsports
NEXT_PUBLIC_TIKTOK_URL=https://tiktok.com/@krakenmotorsports

# Launch Date (format: YYYY-MM-DD)
NEXT_PUBLIC_LAUNCH_DATE=2026-07-01

# Disable the site for maintenance. Set to '1' or 'true' to enable maintenance mode.
# When enabled, requests will be served the maintenance page. To re-enable the site,
# remove this variable or set it to '0' and restart the dev/prod server.
NEXT_PUBLIC_APP_DISABLED=1